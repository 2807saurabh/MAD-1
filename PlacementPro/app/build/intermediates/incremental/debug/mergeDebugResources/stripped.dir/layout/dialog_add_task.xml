<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp"
    android:background="@color/card_bg">

    <EditText android:id="@+id/et_task_title"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="Task Title *" android:textColor="#FFFFFF"
        android:textColorHint="#606080" android:background="@drawable/card_rounded"
        android:padding="12dp" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_task_desc"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="Description (optional)" android:textColor="#FFFFFF"
        android:textColorHint="#606080" android:background="@drawable/card_rounded"
        android:padding="12dp" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Priority" android:textColor="#B0B0C8" android:textSize="12sp"
        android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_priority"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@drawable/card_rounded" android:padding="8dp"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Category" android:textColor="#B0B0C8" android:textSize="12sp"
        android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinner_category"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@drawable/card_rounded" android:padding="8dp"
        android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tv_due_date"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="📅 Tap to pick due date"
        android:textColor="#B0B0C8" android:background="@drawable/card_rounded"
        android:padding="12dp" android:gravity="center_vertical"/>
</LinearLayout>
