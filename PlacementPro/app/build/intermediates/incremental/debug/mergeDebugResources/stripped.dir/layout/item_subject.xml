<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp" app:cardElevation="6dp"
    app:cardBackgroundColor="#1E1E2E"
    app:strokeColor="#2E2E4E" app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

        <TextView android:id="@+id/tv_subject_emoji"
            android:layout_width="56dp" android:layout_height="56dp"
            android:textSize="28sp" android:gravity="center"
            android:background="@drawable/card_rounded"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView android:id="@+id/tv_subject_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>

            <TextView android:id="@+id/tv_subject_category"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#6C63FF" android:textSize="11sp" android:layout_marginTop="2dp"/>

            <TextView android:id="@+id/tv_subject_importance"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#B0B0C8" android:textSize="11sp" android:layout_marginTop="2dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ProgressBar android:id="@+id/pb_subject"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1"
                    android:progressDrawable="@drawable/progress_bar_style"
                    android:max="100"/>

                <TextView android:id="@+id/tv_subject_percent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0%" android:textColor="#6C63FF"
                    android:textSize="12sp" android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView android:id="@+id/tv_subject_topics"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#B0B0C8" android:textSize="11sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="#6C63FF" android:textSize="24sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
