<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:gravity="center" android:orientation="vertical">

    <LinearLayout
        android:layout_width="120dp" android:layout_height="120dp"
        android:background="@drawable/gradient_accent"
        android:gravity="center" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🚀" android:textSize="48sp"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_splash_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="PlacementPro"
        android:textColor="@color/text_primary" android:textSize="36sp" android:textStyle="bold"/>

    <TextView android:id="@+id/tv_splash_sub"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your Placement Journey Starts Here"
        android:textColor="@color/text_secondary" android:textSize="14sp"/>

    <ProgressBar android:layout_width="48dp" android:layout_height="48dp"
        android:layout_marginTop="64dp"
        android:indeterminateTint="@color/accent_color"/>

</LinearLayout>
