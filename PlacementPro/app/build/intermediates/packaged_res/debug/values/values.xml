<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_blue">#4FC3F7</color>
    <color name="accent_color">#6C63FF</color>
    <color name="accent_green">#00D9A3</color>
    <color name="accent_orange">#FF8C42</color>
    <color name="accent_secondary">#FF6584</color>
    <color name="accent_yellow">#FFD166</color>
    <color name="bg_primary">#0D0D0D</color>
    <color name="bg_secondary">#1A1A2E</color>
    <color name="bg_tertiary">#16213E</color>
    <color name="card_bg">#1E1E2E</color>
    <color name="card_bg_2">#252535</color>
    <color name="color_dbms">#4ECDC4</color>
    <color name="color_dsa">#FF6B6B</color>
    <color name="color_java">#FF8C42</color>
    <color name="color_os">#45B7D1</color>
    <color name="color_python">#A8E6CF</color>
    <color name="divider_color">#2A2A3E</color>
    <color name="error">#FF4757</color>
    <color name="info">#4FC3F7</color>
    <color name="priority_high">#FF4757</color>
    <color name="priority_low">#00D9A3</color>
    <color name="priority_medium">#FFD166</color>
    <color name="ripple_color">#336C63FF</color>
    <color name="stroke_color">#2E2E4E</color>
    <color name="success">#00D9A3</color>
    <color name="text_hint">#606080</color>
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#B0B0C8</color>
    <color name="toolbar_color">#12122A</color>
    <color name="warning">#FFD166</color>
    <string name="app_name">PlacementPro</string>
    <string name="navigation_drawer_close">Close</string>
    <string name="navigation_drawer_open">Open</string>
    <style name="AccentButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_color</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="CardStyleDark" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">8dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="strokeColor">@color/stroke_color</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="CardStyleDark2" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/card_bg_2</item>
    </style>
    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/stroke_color</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/card_bg</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
    <style name="Theme.PlacementPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/accent_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="Theme.PlacementPro.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
    </style>
</resources>